# =============================================================================
# Quotr — environment variables
# =============================================================================
# Copy this file to `.env.local` for local development and fill in real values.
# `.env.local` is gitignored — never commit real keys.
# In Vercel, set the same variable names under Project Settings → Environment
# Variables (Production, Preview, Development).
# =============================================================================

# ---- Supabase (new opaque key format, not legacy anon/service_role) ---------
# URL and publishable key are safe to embed in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://xrokfcnfamonqlnlaloj.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Secret key is server-only. Used by the Stripe webhook and any admin routes
# that need to bypass RLS. Never prefix with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_xxx

# ---- Stripe (test mode keys for local + preview; swap to live at launch) ----
# Publishable key is safe to embed in the browser bundle.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Secret key is server-only.
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook signing secret (Stripe CLI prints this when you run `stripe listen`,
# or the Dashboard shows it under the webhook endpoint config).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Stripe price IDs (created in the Dashboard, one per pack) --------------
# Filled in after you create two Products → Prices in Stripe:
#   Starter pack — $29 one-time — 10 credits
#   Pro pack     — $79 one-time — 40 credits
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_xxx

# ---- App config -------------------------------------------------------------
# Used for Stripe return URLs and magic-link redirect.
# Local: http://localhost:3000 — Preview/Prod: https://quotr.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
